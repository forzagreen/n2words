{
  // Code Quality (Project Standards)
  "editor.tabSize": 2,
  "editor.detectIndentation": false, // Respect .editorconfig
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.eol": "\n", // LF line endings (matches .editorconfig)

  // ESLint flat config (ESLint 10) is the project linter
  "eslint.useFlatConfig": true,
  "javascript.preferences.quoteStyle": "single",

  // Auto-fix on save using code actions (modern approach)
  "editor.formatOnSave": false, // Disable default formatter
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },

  // Markdown linting follows the project's .markdownlint.mjs / .markdownlint-cli2.mjs,
  // which the extension auto-discovers — no inline mirror to drift out of sync.

  // TypeScript - JSDoc type checking; pin the editor to the workspace TypeScript
  // (node_modules) so in-editor checks use the same tsc version as CI.
  "javascript.validate.enable": true,
  "typescript.validate.enable": true,
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,

  // Project Build Artifacts & Performance
  "search.exclude": {
    "**/node_modules": true,
    "**/coverage": true,
    "**/dist": true,
    "**/*.d.ts": true,
    "**/.nyc_output": true,
    "**/package-lock.json": true,
    "**/.claude": true,
    "**/.cursor": true,
    "**/.copilot": true
  },
  "files.exclude": {
    "**/.DS_Store": true,
    "**/Thumbs.db": true
  },
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/coverage/**": true,
    "**/dist/**": true,
    "**/.nyc_output/**": true,
    "**/.claude/**": true,
    "**/.cursor/**": true,
    "**/.copilot/**": true
  },

  // NPM Scripts - Quick access to common commands
  "npm.scriptExplorerAction": "run",

  // Git - Better commit message UX (aligned with commitlint)
  "git.inputValidationLength": 100, // Matches header-max-length in .commitlintrc.mjs
  "git.inputValidationSubjectLength": 100,

  // Files - Project-specific patterns
  "files.associations": {
    ".commitlintrc.mjs": "javascript",
    ".markdownlint.mjs": "javascript"
  }
}
