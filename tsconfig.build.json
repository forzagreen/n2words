{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "checkJs": true,
    "noEmitOnError": true,
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": ".",
    "rootDir": "."
  },
  "include": ["src/**/*.js"],
  "exclude": ["node_modules", "dist", "test", "bench", "scripts"]
}
